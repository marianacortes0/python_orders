<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page page-sm">
  <div class="breadcrumb">
    <a href="/suppliers">Proveedores</a>
    <span class="breadcrumb-sep">/</span>
    <% if (supplier) { %>
      <a href="/suppliers/<%= supplier.id %>"><%= supplier.companyName %></a>
      <span class="breadcrumb-sep">/</span><span>Editar</span>
    <% } else { %>
      <span>Nuevo</span>
    <% } %>
  </div>

  <div class="card">
    <div class="card-title"><%= title %></div>
    <div id="formProveedor"></div>
    <div class="mt-24" style="display:flex;gap:8px">
      <div id="btnGuardar"></div>
      <div id="btnCancelar"></div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<script>
  const isEdit     = <%- supplier ? 'true' : 'false' %>;
  const supplierId = <%- supplier ? supplier.id : 'null' %>;
  const initialData = <%- JSON.stringify(supplier || {}) %>;

  const form = new DevExpress.ui.dxForm(document.getElementById('formProveedor'), {
    formData: Object.assign({}, initialData),
    labelLocation: 'top',
    colCount: 2,
    items: [
      { dataField: 'companyName',  label: { text: 'Empresa' },  colSpan: 2, validationRules: [{ type: 'required', message: 'Requerido' }] },
      { dataField: 'contactName',  label: { text: 'Contacto' } },
      { dataField: 'contactTitle', label: { text: 'Cargo' } },
      { dataField: 'city',         label: { text: 'Ciudad' } },
      { dataField: 'country',      label: { text: 'País' } },
      { dataField: 'phone',        label: { text: 'Teléfono' } },
      { dataField: 'fax',          label: { text: 'Fax' } },
    ],
  });

  new DevExpress.ui.dxButton(document.getElementById('btnGuardar'), {
    text: 'Guardar', type: 'default', icon: 'check',
    onClick: async () => {
      if (!form.validate().isValid) return;
      const data   = form.option('formData');
      const url    = isEdit ? `/api/suppliers/${supplierId}` : '/api/suppliers';
      const method = isEdit ? 'PATCH' : 'POST';
      try {
        const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        if (!res.ok) { DevExpress.ui.notify((await res.json()).detail || 'Error al guardar', 'error', 3000); return; }
        const saved = await res.json();
        location.href = `/suppliers/${saved.id}`;
      } catch { DevExpress.ui.notify('Error de conexión', 'error', 3000); }
    },
  });

  new DevExpress.ui.dxButton(document.getElementById('btnCancelar'), {
    text: 'Cancelar', type: 'normal', onClick: () => history.back(),
  });
</script>
