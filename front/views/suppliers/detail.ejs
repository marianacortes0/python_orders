<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page">
  <div class="breadcrumb">
    <a href="/suppliers">Proveedores</a>
    <span class="breadcrumb-sep">/</span>
    <span><%= supplier.companyName %></span>
  </div>

  <div class="page-header">
    <h1 class="page-title"><%= supplier.companyName %></h1>
    <div id="btnEditar"></div>
  </div>

  <div style="display:grid;grid-template-columns:300px 1fr;gap:20px">
    <div class="card">
      <div class="card-title">Datos del proveedor</div>
      <ul class="detail-list">
        <li><span class="label">ID</span><span class="value"><%= supplier.id %></span></li>
        <% if (supplier.contactName) { %>
        <li><span class="label">Contacto</span><span class="value"><%= supplier.contactName %></span></li>
        <% } %>
        <% if (supplier.contactTitle) { %>
        <li><span class="label">Cargo</span><span class="value"><%= supplier.contactTitle %></span></li>
        <% } %>
        <li><span class="label">Ciudad</span><span class="value"><%= supplier.city || '—' %></span></li>
        <li><span class="label">País</span><span class="value"><%= supplier.country || '—' %></span></li>
        <li><span class="label">Teléfono</span><span class="value"><%= supplier.phone || '—' %></span></li>
        <% if (supplier.fax) { %>
        <li><span class="label">Fax</span><span class="value"><%= supplier.fax %></span></li>
        <% } %>
      </ul>
    </div>

    <div class="card" style="padding:0">
      <div class="card-title" style="padding:16px 20px 12px;margin:0">Productos de este proveedor</div>
      <div id="gridProductos"></div>
    </div>
  </div>
</div>


<script>
  new DevExpress.ui.dxButton(document.getElementById('btnEditar'), {
    text: 'Editar', icon: 'edit', type: 'default',
    onClick: () => location.href = '/suppliers/<%= supplier.id %>/edit',
  });

  const products = <%- JSON.stringify(products || []) %>;

  new DevExpress.ui.dxDataGrid(document.getElementById('gridProductos'), {
    dataSource: products,
    showBorders: false,
    showRowLines: true,
    paging: { pageSize: 10 },
    pager: { showInfo: true },
    columns: [
      { dataField: 'productName',    caption: 'Producto' },
      { dataField: 'unitPrice',      caption: 'Precio',  format: { type: 'currency', precision: 2 }, width: 100 },
      { dataField: 'package',        caption: 'Envase',  width: 130 },
      {
        dataField: 'isDiscontinued', caption: 'Estado', width: 120,
        cellTemplate: (el, info) => {
          el.innerHTML = info.value
            ? '<span class="badge badge-disc">Descontinuado</span>'
            : '<span class="badge badge-active">Activo</span>';
        },
      },
      {
        type: 'buttons', width: 60,
        buttons: [{ icon: 'eyeopen', hint: 'Ver', onClick: e => location.href = `/products/${e.row.data.id}` }],
      },
    ],
  });
</script>

<%- include('../partials/footer') %>
