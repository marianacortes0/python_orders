<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-truck me-2 text-danger"></i>Proveedores</h2>
    <a href="/suppliers/new" class="btn btn-danger"><i class="bi bi-plus-lg me-1"></i>Nuevo Proveedor</a>
  </div>

  <form class="row g-2 mb-4" method="get" action="/suppliers">
    <div class="col-md-5">
      <input type="text" name="search" class="form-control" placeholder="Buscar por empresa o contacto..." value="<%= query.search || '' %>">
    </div>
    <div class="col-md-4">
      <input type="text" name="country" class="form-control" placeholder="País" value="<%= query.country || '' %>">
    </div>
    <div class="col-md-3">
      <button class="btn btn-outline-secondary w-100" type="submit"><i class="bi bi-search me-1"></i>Filtrar</button>
    </div>
  </form>

  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Empresa</th>
            <th>Contacto</th>
            <th>Ciudad</th>
            <th>País</th>
            <th>Teléfono</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if (items.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-4">Sin resultados</td></tr>
          <% } %>
          <% items.forEach(s => { %>
          <tr>
            <td class="text-muted"><%= s.id %></td>
            <td class="fw-semibold"><%= s.companyName %></td>
            <td><%= s.contactName || '—' %></td>
            <td><%= s.city || '—' %></td>
            <td><%= s.country || '—' %></td>
            <td><%= s.phone || '—' %></td>
            <td class="text-end">
              <a href="/suppliers/<%= s.id %>" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-eye"></i></a>
              <a href="/suppliers/<%= s.id %>/edit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('../partials/pagination', { page, limit, total, base: '/suppliers', query }) %>
</div>

<%- include('../partials/footer') %>
