<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container py-5">
  <div class="text-center mb-5">
    <h1 class="display-5 fw-bold"><i class="bi bi-box-seam text-primary me-2"></i>Python Orders</h1>
    <p class="lead text-muted">Sistema de gestión de pedidos, clientes, productos y proveedores</p>
  </div>

  <div class="row g-4 justify-content-center">
    <div class="col-md-6 col-lg-3">
      <a href="/orders" class="text-decoration-none">
        <div class="card h-100 border-0 shadow-sm hover-card text-center p-4">
          <div class="fs-1 text-primary mb-3"><i class="bi bi-receipt"></i></div>
          <h5 class="fw-semibold">Pedidos</h5>
          <p class="text-muted small">Gestiona pedidos, ítems y estados</p>
        </div>
      </a>
    </div>
    <div class="col-md-6 col-lg-3">
      <a href="/customers" class="text-decoration-none">
        <div class="card h-100 border-0 shadow-sm hover-card text-center p-4">
          <div class="fs-1 text-success mb-3"><i class="bi bi-people"></i></div>
          <h5 class="fw-semibold">Clientes</h5>
          <p class="text-muted small">Consulta y administra clientes</p>
        </div>
      </a>
    </div>
    <div class="col-md-6 col-lg-3">
      <a href="/products" class="text-decoration-none">
        <div class="card h-100 border-0 shadow-sm hover-card text-center p-4">
          <div class="fs-1 text-warning mb-3"><i class="bi bi-bag"></i></div>
          <h5 class="fw-semibold">Productos</h5>
          <p class="text-muted small">Catálogo de productos disponibles</p>
        </div>
      </a>
    </div>
    <div class="col-md-6 col-lg-3">
      <a href="/suppliers" class="text-decoration-none">
        <div class="card h-100 border-0 shadow-sm hover-card text-center p-4">
          <div class="fs-1 text-danger mb-3"><i class="bi bi-truck"></i></div>
          <h5 class="fw-semibold">Proveedores</h5>
          <p class="text-muted small">Administra tus proveedores</p>
        </div>
      </a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
