<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page">
  <div class="breadcrumb">
    <a href="/orders">Pedidos</a>
    <span class="breadcrumb-sep">/</span>
    <span>Pedido #<%= order.orderNumber %></span>
  </div>

  <div class="page-header">
    <h1 class="page-title">Pedido #<%= order.orderNumber %></h1>
    <div style="display:flex;gap:8px">
      <div id="btnEstado"></div>
      <div id="btnEliminar"></div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:300px 1fr;gap:20px">
    <!-- Info -->
    <div>
      <div class="card">
        <div class="card-title">Información</div>
        <ul class="detail-list">
          <li><span class="label">Estado</span>
            <span class="value"><span id="badgeEstado" class="badge badge-<%= order.status %>"><%= order.status %></span></span>
          </li>
          <li>
            <span class="label">Cliente</span>
            <span class="value">
              <a href="/customers/<%= order.customer.id %>">
                <%= order.customer.firstName %> <%= order.customer.lastName %>
              </a>
            </span>
          </li>
          <li><span class="label">Fecha</span><span class="value"><%= new Date(order.orderDate).toLocaleDateString('es-AR') %></span></li>
          <li><span class="label">Total</span><span class="value fw-bold">$<%= order.totalAmount.toFixed(2) %></span></li>
        </ul>
      </div>

      <!-- Cambiar estado -->
      <div class="card">
        <div class="card-title">Cambiar estado</div>
        <div id="selectEstado"></div>
        <div class="mt-16"><div id="btnCambiarEstado"></div></div>
      </div>
    </div>

    <!-- Ítems -->
    <div>
      <div class="card" style="padding:0">
        <div class="card-title" style="padding:16px 20px 12px;margin:0">Ítems del pedido</div>
        <div id="gridItems"></div>
      </div>

      <!-- Agregar ítem -->
      <div class="card">
        <div class="card-title">Agregar ítem</div>
        <div id="formAgregarItem"></div>
        <div class="mt-16"><div id="btnAgregarItem"></div></div>
      </div>
    </div>
  </div>
</div>


<script>
  const orderId  = <%= order.id %>;
  const products = <%- JSON.stringify(products || []) %>;
  const statuses = ['pending','confirmed','shipped','delivered','cancelled'];
  const statusLabels = { pending:'Pendiente', confirmed:'Confirmado', shipped:'Enviado', delivered:'Entregado', cancelled:'Cancelado' };

  // ── Cambiar estado ──
  const selectEstado = new DevExpress.ui.dxSelectBox(document.getElementById('selectEstado'), {
    items: statuses.map(s => ({ value: s, label: statusLabels[s] })),
    valueExpr: 'value', displayExpr: 'label',
    value: '<%= order.status %>',
  });

  new DevExpress.ui.dxButton(document.getElementById('btnCambiarEstado'), {
    text: 'Aplicar', type: 'default',
    onClick: async () => {
      const status = selectEstado.option('value');
      const res = await fetch(`/api/orders/${orderId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status }),
      });
      if (res.ok) location.reload();
      else DevExpress.ui.notify('Error al cambiar estado', 'error', 3000);
    },
  });

  // ── Eliminar pedido ──
  new DevExpress.ui.dxButton(document.getElementById('btnEliminar'), {
    text: 'Eliminar', icon: 'trash', type: 'danger',
    onClick: () => {
      DevExpress.ui.dialog.confirm('¿Eliminar este pedido?', 'Confirmar').then(async ok => {
        if (!ok) return;
        const res = await fetch(`/api/orders/${orderId}`, { method: 'DELETE' });
        if (res.ok || res.status === 204) location.href = '/orders';
        else DevExpress.ui.notify('No se pudo eliminar', 'error', 3000);
      });
    },
  });

  // ── DataGrid de ítems ──
  const itemsStore = new DevExpress.data.CustomStore({
    key: 'id',
    load: () => fetch(`/api/orders/${orderId}/items`).then(r => r.json()),
    update: (key, values) => fetch(`/api/orders/${orderId}/items/${key}`, {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(values),
    }).then(r => r.json()),
    remove: (key) => fetch(`/api/orders/${orderId}/items/${key}`, { method: 'DELETE' }),
  });

  new DevExpress.ui.dxDataGrid(document.getElementById('gridItems'), {
    dataSource: itemsStore,
    showBorders: false,
    showRowLines: true,
    editing: { mode: 'row', allowUpdating: true, allowDeleting: true },
    columns: [
      { dataField: 'product.productName', caption: 'Producto',  allowEditing: false },
      { dataField: 'unitPrice',           caption: 'Precio',    format: { type: 'currency', precision: 2 }, allowEditing: false },
      { dataField: 'quantity',            caption: 'Cantidad',  dataType: 'number', validationRules: [{ type: 'range', min: 1 }] },
      {
        caption: 'Subtotal', allowEditing: false,
        calculateCellValue: row => row.unitPrice && row.quantity ? (row.unitPrice * row.quantity).toFixed(2) : '',
        cellTemplate: (el, info) => { if (info.value) el.textContent = `$${info.value}`; },
      },
    ],
  });

  // ── Agregar ítem ──
  const addFormData = { productId: null, quantity: 1, unitPrice: null };

  const addForm = new DevExpress.ui.dxForm(document.getElementById('formAgregarItem'), {
    formData: addFormData,
    labelLocation: 'top',
    colCount: 3,
    items: [
      {
        dataField: 'productId', label: { text: 'Producto' },
        editorType: 'dxSelectBox',
        editorOptions: { dataSource: products, valueExpr: 'id', displayExpr: 'productName', searchEnabled: true, placeholder: 'Seleccionar...' },
        validationRules: [{ type: 'required' }],
      },
      {
        dataField: 'quantity', label: { text: 'Cantidad' },
        editorType: 'dxNumberBox',
        editorOptions: { min: 1, value: 1 },
        validationRules: [{ type: 'required' }, { type: 'range', min: 1 }],
      },
      {
        dataField: 'unitPrice', label: { text: 'Precio (opcional)' },
        editorType: 'dxNumberBox',
        editorOptions: { min: 0.01, placeholder: 'Auto' },
      },
    ],
  });

  new DevExpress.ui.dxButton(document.getElementById('btnAgregarItem'), {
    text: 'Agregar ítem', type: 'default', icon: 'plus',
    onClick: async () => {
      if (!addForm.validate().isValid) return;
      const data = addForm.option('formData');
      const body = { productId: data.productId, quantity: data.quantity };
      if (data.unitPrice) body.unitPrice = data.unitPrice;
      const res = await fetch(`/api/orders/${orderId}/items`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
      });
      if (res.ok) location.reload();
      else DevExpress.ui.notify((await res.json()).detail || 'Error al agregar ítem', 'error', 3000);
    },
  });
</script>

<%- include('../partials/footer') %>
