<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4" style="max-width:760px">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/orders">Pedidos</a></li>
      <li class="breadcrumb-item active">Nuevo Pedido</li>
    </ol>
  </nav>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <h4 class="fw-bold mb-4"><%= title %></h4>

      <% if (errors) { %>
        <div class="alert alert-danger"><i class="bi bi-exclamation-circle me-2"></i><%= errors.detail || 'Error en el formulario' %></div>
      <% } %>

      <form method="post" action="/orders" id="orderForm">
        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Cliente <span class="text-danger">*</span></label>
            <select name="customerId" class="form-select" required>
              <option value="">Seleccionar cliente...</option>
              <% customers.forEach(c => { %>
                <option value="<%= c.id %>"><%= c.firstName %> <%= c.lastName %> (<%= c.country || '—' %>)</option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold">N° de Pedido</label>
            <input type="text" name="orderNumber" class="form-control" placeholder="Auto-generado">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold">Fecha</label>
            <input type="datetime-local" name="orderDate" class="form-control">
          </div>
        </div>

        <h6 class="fw-bold mb-3">Ítems <span class="text-danger">*</span></h6>
        <div id="itemsContainer">
          <div class="row g-2 mb-2 item-row">
            <div class="col-md-5">
              <select name="productId" class="form-select form-select-sm" required>
                <option value="">Producto...</option>
                <% products.forEach(p => { %>
                  <option value="<%= p.id %>"><%= p.productName %> — $<%= p.unitPrice.toFixed(2) %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-3">
              <input type="number" name="quantity" min="1" value="1" class="form-control form-control-sm" placeholder="Cantidad" required>
            </div>
            <div class="col-md-3">
              <input type="number" step="0.01" name="unitPrice" class="form-control form-control-sm" placeholder="Precio (auto)">
            </div>
            <div class="col-md-1">
              <button type="button" class="btn btn-outline-danger btn-sm w-100 remove-item"><i class="bi bi-x-lg"></i></button>
            </div>
          </div>
        </div>

        <button type="button" id="addItem" class="btn btn-outline-secondary btn-sm mb-4">
          <i class="bi bi-plus-lg me-1"></i>Agregar ítem
        </button>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Crear Pedido</button>
          <a href="/orders" class="btn btn-outline-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  const productsHtml = `<% products.forEach(p => { %><option value="<%= p.id %>"><%= p.productName %> — $<%= p.unitPrice.toFixed(2) %></option><% }) %>`;

  document.getElementById('addItem').addEventListener('click', () => {
    const container = document.getElementById('itemsContainer');
    const row = document.createElement('div');
    row.className = 'row g-2 mb-2 item-row';
    row.innerHTML = `
      <div class="col-md-5">
        <select name="productId" class="form-select form-select-sm" required>
          <option value="">Producto...</option>
          ${productsHtml}
        </select>
      </div>
      <div class="col-md-3">
        <input type="number" name="quantity" min="1" value="1" class="form-control form-control-sm" placeholder="Cantidad" required>
      </div>
      <div class="col-md-3">
        <input type="number" step="0.01" name="unitPrice" class="form-control form-control-sm" placeholder="Precio (auto)">
      </div>
      <div class="col-md-1">
        <button type="button" class="btn btn-outline-danger btn-sm w-100 remove-item"><i class="bi bi-x-lg"></i></button>
      </div>`;
    container.appendChild(row);
  });

  document.getElementById('itemsContainer').addEventListener('click', (e) => {
    if (e.target.closest('.remove-item')) {
      const rows = document.querySelectorAll('.item-row');
      if (rows.length > 1) e.target.closest('.item-row').remove();
    }
  });
</script>

<%- include('../partials/footer') %>
