<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page" style="max-width:860px">
  <div class="breadcrumb">
    <a href="/orders">Pedidos</a>
    <span class="breadcrumb-sep">/</span>
    <span>Nuevo</span>
  </div>

  <div class="card">
    <div class="card-title">Nuevo Pedido</div>
    <div id="formPedido"></div>
  </div>

  <div class="card">
    <div class="card-title">Ítems <span style="color:#c62828">*</span></div>
    <div id="gridItems"></div>
    <div class="mt-16" style="display:flex;gap:8px">
      <div id="btnAgregarItem"></div>
    </div>
  </div>

  <div style="display:flex;gap:8px">
    <div id="btnGuardar"></div>
    <div id="btnCancelar"></div>
  </div>
</div>


<script>
  const customers = <%- JSON.stringify(customers) %>;
  const products  = <%- JSON.stringify(products) %>;
  const items = [];

  const form = new DevExpress.ui.dxForm(document.getElementById('formPedido'), {
    formData: {},
    labelLocation: 'top',
    colCount: 3,
    items: [
      {
        dataField: 'customerId', label: { text: 'Cliente' }, colSpan: 2,
        editorType: 'dxSelectBox',
        editorOptions: { dataSource: customers, valueExpr: 'id', displayExpr: d => `${d.firstName} ${d.lastName}`, searchEnabled: true, placeholder: 'Seleccionar...' },
        validationRules: [{ type: 'required', message: 'Requerido' }],
      },
      {
        dataField: 'orderNumber', label: { text: 'N° Pedido' },
        editorOptions: { placeholder: 'Auto-generado' },
      },
      {
        dataField: 'orderDate', label: { text: 'Fecha' },
        editorType: 'dxDateBox',
        editorOptions: { type: 'datetime', displayFormat: 'dd/MM/yyyy HH:mm' },
      },
    ],
  });

  // ── DataGrid editable local para ítems ──
  const itemsSource = new DevExpress.data.ArrayStore({ key: '_id', data: items });

  const gridItems = new DevExpress.ui.dxDataGrid(document.getElementById('gridItems'), {
    dataSource: new DevExpress.data.DataSource({ store: itemsSource }),
    showBorders: true,
    editing: { mode: 'row', allowUpdating: true, allowDeleting: true, newRowPosition: 'last' },
    columns: [
      {
        dataField: 'productId', caption: 'Producto',
        lookup: { dataSource: products, valueExpr: 'id', displayExpr: 'productName' },
        validationRules: [{ type: 'required' }],
      },
      { dataField: 'quantity',  caption: 'Cantidad', dataType: 'number', validationRules: [{ type: 'required' }, { type: 'range', min: 1 }] },
      { dataField: 'unitPrice', caption: 'Precio (opcional)', dataType: 'number' },
    ],
    onRowInserted: (e) => { e.data._id = Date.now(); },
  });

  new DevExpress.ui.dxButton(document.getElementById('btnAgregarItem'), {
    text: 'Agregar fila', icon: 'plus', type: 'normal',
    onClick: () => gridItems.addRow(),
  });

  new DevExpress.ui.dxButton(document.getElementById('btnGuardar'), {
    text: 'Crear Pedido', type: 'default', icon: 'check',
    onClick: async () => {
      if (!form.validate().isValid) return;

      const rows = gridItems.getDataSource().items();
      if (!rows.length) {
        DevExpress.ui.notify('Agregá al menos un ítem', 'warning', 3000);
        return;
      }

      const formData = form.option('formData');
      const payload = {
        customerId:  formData.customerId,
        orderNumber: formData.orderNumber || undefined,
        orderDate:   formData.orderDate   || undefined,
        items: rows.map(r => ({
          productId: r.productId,
          quantity:  r.quantity,
          unitPrice: r.unitPrice || undefined,
        })),
      };

      try {
        const res = await fetch('/api/orders', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) { DevExpress.ui.notify((await res.json()).detail || 'Error al crear', 'error', 3000); return; }
        const saved = await res.json();
        location.href = `/orders/${saved.id}`;
      } catch { DevExpress.ui.notify('Error de conexión', 'error', 3000); }
    },
  });

  new DevExpress.ui.dxButton(document.getElementById('btnCancelar'), {
    text: 'Cancelar', type: 'normal', onClick: () => history.back(),
  });
</script>

<%- include('../partials/footer') %>
