<%
  const totalPages = Math.ceil(total / limit);
  if (totalPages > 1) {
    const q = Object.assign({}, query);
%>
<nav class="mt-3">
  <ul class="pagination justify-content-center">
    <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
      <% q.page = page - 1; %>
      <a class="page-link" href="<%= base %>?<%= new URLSearchParams(q).toString() %>">Anterior</a>
    </li>
    <% for (let p = 1; p <= totalPages; p++) { %>
      <li class="page-item <%= p == page ? 'active' : '' %>">
        <% q.page = p; %>
        <a class="page-link" href="<%= base %>?<%= new URLSearchParams(q).toString() %>"><%= p %></a>
      </li>
    <% } %>
    <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
      <% q.page = +page + 1; %>
      <a class="page-link" href="<%= base %>?<%= new URLSearchParams(q).toString() %>">Siguiente</a>
    </li>
  </ul>
  <p class="text-center text-muted small">Total: <%= total %> registros</p>
</nav>
<% } %>
