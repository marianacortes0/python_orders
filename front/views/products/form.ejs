<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page page-sm">
  <div class="breadcrumb">
    <a href="/products">Productos</a>
    <span class="breadcrumb-sep">/</span>
    <% if (product) { %>
      <a href="/products/<%= product.id %>"><%= product.productName %></a>
      <span class="breadcrumb-sep">/</span><span>Editar</span>
    <% } else { %>
      <span>Nuevo</span>
    <% } %>
  </div>

  <div class="card">
    <div class="card-title"><%= title %></div>
    <div id="formProducto"></div>
    <div class="mt-24" style="display:flex;gap:8px">
      <div id="btnGuardar"></div>
      <div id="btnCancelar"></div>
    </div>
  </div>
</div>


<script>
  const isEdit    = <%- product ? 'true' : 'false' %>;
  const productId = <%- product ? product.id : 'null' %>;
  const initialData = <%- JSON.stringify(product || {}) %>;
  const suppliers   = <%- JSON.stringify(suppliers) %>;

  const form = new DevExpress.ui.dxForm(document.getElementById('formProducto'), {
    formData: Object.assign({ isDiscontinued: false }, initialData),
    labelLocation: 'top',
    colCount: 2,
    items: [
      {
        dataField: 'productName', label: { text: 'Nombre del producto' }, colSpan: 2,
        validationRules: [{ type: 'required', message: 'Requerido' }],
      },
      {
        dataField: 'supplierId', label: { text: 'Proveedor' },
        editorType: 'dxSelectBox',
        editorOptions: {
          dataSource: suppliers,
          valueExpr: 'id',
          displayExpr: 'companyName',
          searchEnabled: true,
          placeholder: 'Seleccionar...',
        },
        validationRules: [{ type: 'required', message: 'Requerido' }],
      },
      {
        dataField: 'unitPrice', label: { text: 'Precio unitario' },
        editorType: 'dxNumberBox',
        editorOptions: { min: 0.01, format: { type: 'currency', precision: 2 } },
        validationRules: [{ type: 'required', message: 'Requerido' }, { type: 'range', min: 0.01, message: 'Debe ser mayor a 0' }],
      },
      { dataField: 'package', label: { text: 'Envase' } },
      {
        dataField: 'isDiscontinued', label: { text: 'Estado' },
        editorType: 'dxSelectBox',
        editorOptions: {
          items: [{ value: false, label: 'Activo' }, { value: true, label: 'Descontinuado' }],
          valueExpr: 'value',
          displayExpr: 'label',
        },
      },
    ],
  });

  new DevExpress.ui.dxButton(document.getElementById('btnGuardar'), {
    text: 'Guardar', type: 'default', icon: 'check',
    onClick: async () => {
      if (!form.validate().isValid) return;
      const data   = form.option('formData');
      const url    = isEdit ? `/api/products/${productId}` : '/api/products';
      const method = isEdit ? 'PATCH' : 'POST';
      try {
        const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        if (!res.ok) { DevExpress.ui.notify((await res.json()).detail || 'Error al guardar', 'error', 3000); return; }
        const saved = await res.json();
        location.href = `/products/${saved.id}`;
      } catch { DevExpress.ui.notify('Error de conexión', 'error', 3000); }
    },
  });

  new DevExpress.ui.dxButton(document.getElementById('btnCancelar'), {
    text: 'Cancelar', type: 'normal', onClick: () => history.back(),
  });
</script>

<%- include('../partials/footer') %>
