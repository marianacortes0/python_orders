<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4" style="max-width:600px">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/products">Productos</a></li>
      <% if (product) { %>
        <li class="breadcrumb-item"><a href="/products/<%= product.id %>"><%= product.productName %></a></li>
        <li class="breadcrumb-item active">Editar</li>
      <% } else { %>
        <li class="breadcrumb-item active">Nuevo</li>
      <% } %>
    </ol>
  </nav>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <h4 class="fw-bold mb-4"><%= title %></h4>

      <% if (errors) { %>
        <div class="alert alert-danger"><i class="bi bi-exclamation-circle me-2"></i><%= errors.detail || 'Error en el formulario' %></div>
      <% } %>

      <form method="post" action="<%= product ? '/products/' + product.id : '/products' %>">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label fw-semibold">Nombre del producto <span class="text-danger">*</span></label>
            <input type="text" name="productName" class="form-control" required
              value="<%= product ? product.productName : '' %>">
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Proveedor <span class="text-danger">*</span></label>
            <select name="supplierId" class="form-select" required>
              <option value="">Seleccionar...</option>
              <% suppliers.forEach(s => { %>
                <option value="<%= s.id %>" <%= product && product.supplierId == s.id ? 'selected' : '' %>>
                  <%= s.companyName %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Precio unitario <span class="text-danger">*</span></label>
            <div class="input-group">
              <span class="input-group-text">$</span>
              <input type="number" step="0.01" min="0.01" name="unitPrice" class="form-control" required
                value="<%= product ? product.unitPrice : '' %>">
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Envase</label>
            <input type="text" name="package" class="form-control"
              value="<%= product ? (product.package || '') : '' %>">
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Estado</label>
            <select name="isDiscontinued" class="form-select">
              <option value="false" <%= product && !product.isDiscontinued ? 'selected' : '' %>>Activo</option>
              <option value="true" <%= product && product.isDiscontinued ? 'selected' : '' %>>Descontinuado</option>
            </select>
          </div>
          <div class="col-12 d-flex gap-2 mt-2">
            <button type="submit" class="btn btn-warning text-dark"><i class="bi bi-check-lg me-1"></i>Guardar</button>
            <a href="<%= product ? '/products/' + product.id : '/products' %>" class="btn btn-outline-secondary">Cancelar</a>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
