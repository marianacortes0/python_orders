<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4" style="max-width:640px">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/products">Productos</a></li>
      <li class="breadcrumb-item active"><%= product.productName %></li>
    </ol>
  </nav>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-start mb-3">
        <h4 class="fw-bold mb-0"><%= product.productName %></h4>
        <span class="badge bg-warning text-dark">ID <%= product.id %></span>
      </div>

      <dl class="row">
        <dt class="col-sm-4 text-muted">Proveedor</dt>
        <dd class="col-sm-8">
          <a href="/suppliers/<%= product.supplierId %>"><%= product.supplier ? product.supplier.companyName : product.supplierId %></a>
        </dd>
        <dt class="col-sm-4 text-muted">Precio unitario</dt>
        <dd class="col-sm-8 fw-semibold">$<%= product.unitPrice.toFixed(2) %></dd>
        <dt class="col-sm-4 text-muted">Envase</dt>
        <dd class="col-sm-8"><%= product.package || '—' %></dd>
        <dt class="col-sm-4 text-muted">Estado</dt>
        <dd class="col-sm-8">
          <span class="badge <%= product.isDiscontinued ? 'bg-secondary' : 'bg-success' %>">
            <%= product.isDiscontinued ? 'Descontinuado' : 'Activo' %>
          </span>
        </dd>
      </dl>

      <div class="d-flex gap-2 mt-3">
        <a href="/products/<%= product.id %>/edit" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-pencil me-1"></i>Editar
        </a>
        <form method="post" action="/products/<%= product.id %>/delete"
          onsubmit="return confirm('¿Eliminar este producto?')">
          <button type="submit" class="btn btn-outline-danger btn-sm">
            <i class="bi bi-trash me-1"></i>Eliminar
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
