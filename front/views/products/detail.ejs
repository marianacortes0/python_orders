<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page page-sm">
  <div class="breadcrumb">
    <a href="/products">Productos</a>
    <span class="breadcrumb-sep">/</span>
    <span><%= product.productName %></span>
  </div>

  <div class="page-header">
    <h1 class="page-title"><%= product.productName %></h1>
    <div style="display:flex;gap:8px">
      <div id="btnEditar"></div>
      <div id="btnEliminar"></div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Datos del producto</div>
    <ul class="detail-list">
      <li><span class="label">ID</span><span class="value"><%= product.id %></span></li>
      <li>
        <span class="label">Proveedor</span>
        <span class="value">
          <a href="/suppliers/<%= product.supplierId %>">
            <%= product.supplier ? product.supplier.companyName : product.supplierId %>
          </a>
        </span>
      </li>
      <li><span class="label">Precio unitario</span><span class="value">$<%= product.unitPrice.toFixed(2) %></span></li>
      <li><span class="label">Envase</span><span class="value"><%= product.package || '—' %></span></li>
      <li>
        <span class="label">Estado</span>
        <span class="value">
          <% if (product.isDiscontinued) { %>
            <span class="badge badge-disc">Descontinuado</span>
          <% } else { %>
            <span class="badge badge-active">Activo</span>
          <% } %>
        </span>
      </li>
    </ul>
  </div>
</div>


<script>
  new DevExpress.ui.dxButton(document.getElementById('btnEditar'), {
    text: 'Editar', icon: 'edit', type: 'default',
    onClick: () => location.href = '/products/<%= product.id %>/edit',
  });

  new DevExpress.ui.dxButton(document.getElementById('btnEliminar'), {
    text: 'Eliminar', icon: 'trash', type: 'danger',
    onClick: () => {
      DevExpress.ui.dialog.confirm('¿Eliminar este producto? Esta acción no se puede deshacer.', 'Confirmar')
        .then(async (ok) => {
          if (!ok) return;
          const res = await fetch('/api/products/<%= product.id %>', { method: 'DELETE' });
          if (res.ok || res.status === 204) location.href = '/products';
          else DevExpress.ui.notify('No se pudo eliminar', 'error', 3000);
        });
    },
  });
</script>

<%- include('../partials/footer') %>
