<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page">
  <div class="page-header">
    <h1 class="page-title">Productos</h1>
    <div id="btnNuevo"></div>
  </div>
  <div class="card" style="padding:0">
    <div id="gridProductos"></div>
  </div>
</div>


<script>
  new DevExpress.ui.dxButton(document.getElementById('btnNuevo'), {
    text: 'Nuevo Producto', type: 'default', icon: 'plus',
    onClick: () => location.href = '/products/new',
  });

  const store = new DevExpress.data.CustomStore({
    key: 'id',
    load: (opts) => {
      const page  = Math.floor((opts.skip || 0) / (opts.take || 20)) + 1;
      const limit = opts.take || 20;
      const params = new URLSearchParams({ page, limit });
      if (opts.searchValue) params.append('search', opts.searchValue);
      return fetch(`/api/products?${params}`)
        .then(r => r.json())
        .then(d => ({ data: d.items, totalCount: d.total }));
    },
  });

  new DevExpress.ui.dxDataGrid(document.getElementById('gridProductos'), {
    dataSource: store,
    remoteOperations: { paging: true },
    paging: { pageSize: 20 },
    pager:  { showPageSizeSelector: true, allowedPageSizes: [10, 20, 50], showInfo: true },
    filterRow:   { visible: true },
    searchPanel: { visible: true, placeholder: 'Buscar producto...' },
    showBorders: false,
    showRowLines: true,
    columnAutoWidth: true,
    columns: [
      { dataField: 'id',            caption: '#',       width: 60, allowFiltering: false },
      { dataField: 'productName',   caption: 'Producto' },
      { dataField: 'supplier.companyName', caption: 'Proveedor' },
      { dataField: 'unitPrice',     caption: 'Precio',  format: { type: 'currency', precision: 2 }, width: 110 },
      { dataField: 'package',       caption: 'Envase',  width: 130 },
      {
        dataField: 'isDiscontinued', caption: 'Estado', width: 130,
        cellTemplate: (el, info) => {
          el.innerHTML = info.value
            ? '<span class="badge badge-disc">Descontinuado</span>'
            : '<span class="badge badge-active">Activo</span>';
        },
      },
      {
        type: 'buttons', width: 90,
        buttons: [
          { icon: 'eyeopen', hint: 'Ver',    onClick: e => location.href = `/products/${e.row.data.id}` },
          { icon: 'edit',    hint: 'Editar', onClick: e => location.href = `/products/${e.row.data.id}/edit` },
        ],
      },
    ],
  });
</script>

<%- include('../partials/footer') %>
