<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page page-sm">
  <div class="breadcrumb">
    <a href="/customers">Clientes</a>
    <span class="breadcrumb-sep">/</span>
    <% if (customer) { %>
      <a href="/customers/<%= customer.id %>"><%= customer.firstName %> <%= customer.lastName %></a>
      <span class="breadcrumb-sep">/</span><span>Editar</span>
    <% } else { %>
      <span>Nuevo</span>
    <% } %>
  </div>

  <div class="card">
    <div class="card-title"><%= title %></div>
    <div id="formCliente"></div>
    <div class="mt-24" style="display:flex;gap:8px">
      <div id="btnGuardar"></div>
      <div id="btnCancelar"></div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<script>
  const isEdit = <%- customer ? 'true' : 'false' %>;
  const customerId = <%- customer ? customer.id : 'null' %>;
  const initialData = <%- JSON.stringify(customer || {}) %>;

  const form = new DevExpress.ui.dxForm(document.getElementById('formCliente'), {
    formData: Object.assign({}, initialData),
    labelLocation: 'top',
    colCount: 2,
    items: [
      { dataField: 'firstName', label: { text: 'Nombre' },   validationRules: [{ type: 'required', message: 'Requerido' }] },
      { dataField: 'lastName',  label: { text: 'Apellido' }, validationRules: [{ type: 'required', message: 'Requerido' }] },
      { dataField: 'city',    label: { text: 'Ciudad' } },
      { dataField: 'country', label: { text: 'País' } },
      { dataField: 'phone',   label: { text: 'Teléfono' }, colSpan: 2 },
    ],
  });

  new DevExpress.ui.dxButton(document.getElementById('btnGuardar'), {
    text: 'Guardar', type: 'default', icon: 'check',
    onClick: async () => {
      const result = form.validate();
      if (!result.isValid) return;

      const data = form.option('formData');
      const url    = isEdit ? `/api/customers/${customerId}` : '/api/customers';
      const method = isEdit ? 'PATCH' : 'POST';

      try {
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) {
          const err = await res.json();
          DevExpress.ui.notify(err.detail || 'Error al guardar', 'error', 3000);
          return;
        }
        const saved = await res.json();
        location.href = `/customers/${saved.id}`;
      } catch (e) {
        DevExpress.ui.notify('Error de conexión', 'error', 3000);
      }
    },
  });

  new DevExpress.ui.dxButton(document.getElementById('btnCancelar'), {
    text: 'Cancelar', type: 'normal',
    onClick: () => history.back(),
  });
</script>
