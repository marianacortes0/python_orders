<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-people me-2 text-success"></i>Clientes</h2>
    <a href="/customers/new" class="btn btn-success"><i class="bi bi-plus-lg me-1"></i>Nuevo Cliente</a>
  </div>

  <form class="row g-2 mb-4" method="get" action="/customers">
    <div class="col-md-4">
      <input type="text" name="search" class="form-control" placeholder="Buscar por nombre..." value="<%= query.search || '' %>">
    </div>
    <div class="col-md-3">
      <input type="text" name="country" class="form-control" placeholder="País" value="<%= query.country || '' %>">
    </div>
    <div class="col-md-3">
      <input type="text" name="city" class="form-control" placeholder="Ciudad" value="<%= query.city || '' %>">
    </div>
    <div class="col-md-2">
      <button class="btn btn-outline-secondary w-100" type="submit"><i class="bi bi-search me-1"></i>Filtrar</button>
    </div>
  </form>

  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Nombre</th>
            <th>Ciudad</th>
            <th>País</th>
            <th>Teléfono</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if (items.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted py-4">Sin resultados</td></tr>
          <% } %>
          <% items.forEach(c => { %>
          <tr>
            <td class="text-muted"><%= c.id %></td>
            <td class="fw-semibold"><%= c.firstName %> <%= c.lastName %></td>
            <td><%= c.city || '—' %></td>
            <td><%= c.country || '—' %></td>
            <td><%= c.phone || '—' %></td>
            <td class="text-end">
              <a href="/customers/<%= c.id %>" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-eye"></i></a>
              <a href="/customers/<%= c.id %>/edit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('../partials/pagination', { page, limit, total, base: '/customers', query }) %>
</div>

<%- include('../partials/footer') %>
